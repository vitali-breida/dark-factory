# ── Credentials ────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
ANTHROPIC_API_KEY=sk-ant-...

# ── Target repository ───────────────────────────────────────────
TARGET_REPO=owner/repo
TARGET_BRANCH=main
LABEL_FILTER=              # comma-separated; empty = no filter

# ── Pipeline ───────────────────────────────────────────────────
MAX_ISSUES_PER_RUN=5       # how many issues to attempt per run
WORKSPACES_DIR=./workspaces
SETUP_COMMAND=npm install  # run once after clone to install dependencies
TEST_COMMAND=npm test      # command to run the target repo's test suite
TEST_TIMEOUT_MS=300000     # 5 minutes

# ── LLM ────────────────────────────────────────────────────────
FILTER_MODEL=claude-haiku-4-5-20251001   # issue triage (cheap, fast)
FIX_MODEL=claude-sonnet-4-6              # fix generation
MAX_RELEVANT_FILES=10      # max files passed to the fix prompt
MAX_INPUT_TOKENS=150000    # abort if estimated input exceeds this
MAX_FILE_LINES=300         # lines read per file before truncation
